# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node.js の依存関係
/node_modules
/.pnp
.pnp.js

# フロントエンドのビルド関連
/build
/coverage

# ログファイル
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 環境変数ファイル
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS による無視項目
.DS_Store
Thumbs.db

# バックエンド（Go言語）の無視項目

# コンパイルされたバイナリ
/backend/main
/backend/main.exe

# Go ビルドディレクトリ
/backend/bin/
/backend/pkg/

# 環境変数ファイル
/backend/.env

# フロントエンド（React）の無視項目

# ローカルパッケージとビルドファイル
/frontend/node_modules
/frontend/build/
/frontend/dist/

# 環境変数ファイル
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local

# ログファイル
/frontend/npm-debug.log*

# Docker 無視項目
/db-data